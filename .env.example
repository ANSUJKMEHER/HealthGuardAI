# HealthGuard AI — Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE
# ===========================================
# Local development (SQLite fallback)
DATABASE_URL=sqlite:///./healthguard.db
# Production (Neon PostgreSQL) — uncomment below
# DATABASE_URL=postgresql://user:password@host.neon.tech/healthguard?sslmode=require

# ===========================================
# LLM PROVIDER
# ===========================================
# Options: "groq" (free API), "fallback" (rule-based, no API needed)
LLM_PROVIDER=fallback
# Get free API key at https://console.groq.com
GROQ_API_KEY=

# ===========================================
# TARGET APPLICATION
# ===========================================
# The URL of the system being monitored
TARGET_URL=http://127.0.0.1:3000/api

# ===========================================
# SERVER
# ===========================================
HOST=127.0.0.1
PORT=8000
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===========================================
# DEPLOYMENT (set by platform automatically)
# ===========================================
# RENDER_EXTERNAL_URL=  (set automatically by Render)
# VERCEL_URL=           (set automatically by Vercel)
